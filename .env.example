# =============================================================
# VITSYNC-WebApp — Variables de entorno (plantilla)
# =============================================================
# Copia este archivo a `.env` y rellena los valores para desarrollo.
# En Vercel, configura estas variables en el dashboard del proyecto.
#
# IMPORTANTE: todo lo que empiece por VITE_ se incrusta en el bundle
# JS público en build. NUNCA pongas secretos aquí (API keys privadas,
# tokens, contraseñas): cualquier visitante puede leerlos.
# =============================================================

# URL base de la API backend (VITSYNC-API, Spring Boot)
# Desarrollo local:
VITE_API_URL=http://localhost:8080
# Testing:  https://vitsync-api-testing.onrender.com
# Producción: configurar en Vercel

# App ID de TalkJS para el chat (identificador público de cliente,
# no es secreto; la Secret Key de TalkJS vive SOLO en el backend)
VITE_TALKJS_APP_ID=tu-app-id-de-talkjs
